# ── 프롬프트 인젝션 가드 환경설정 예시 ──
# 이 파일을 .env로 복사한 뒤 값을 채우세요. (.env는 절대 커밋하지 않습니다)

# Anthropic API 키 — 2차(LLM) 레이어용.
# 없어도 1차(룰) 레이어로 알려진 공격은 잡습니다. 키가 있으면 신종·맥락형까지 탐지.
# 발급: https://console.anthropic.com
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY_HERE

# 분류기는 빠르고 저렴한 모델이 적합합니다.
ANTHROPIC_MODEL=claude-sonnet-4-6
# 더 빠르고 싸게: ANTHROPIC_MODEL=claude-haiku-4-5
